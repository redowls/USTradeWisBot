# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- Alpaca (use PAPER keys until Phase 12) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# --- Telegram (needed from Phase 9) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- SQL Server ---
DB_SERVER=localhost,1433
DB_NAME=USTradeWisBot
DB_USER=sa
DB_PASSWORD=
# ODBC driver name as registered with unixODBC (see: odbcinst -q -d)
DB_DRIVER=ODBC Driver 18 for SQL Server
# Self-signed local SQL Server cert -> trust it. Set to false for a verified cert.
DB_TRUST_CERT=true
